# ─────────────────────────────────────────────────────────────
#  Single shared environment file for the whole stack.
#  Copy to `.env` and replace every placeholder with real values.
#  The real `.env` is git-ignored and is NEVER committed.
#  (Each service reads only the variables it needs; extras are ignored.)
# ─────────────────────────────────────────────────────────────

# ─── PostgreSQL ───
POSTGRES_USER=shortener
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=shortener
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis (hot-link cache) ───
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL_SECONDS=3600

# ─── Short-code generation ───
SHORT_CODE_LENGTH=7
DEFAULT_LINK_TTL_DAYS=0          # 0 = links never expire by default

# ─── Public base URL (gateway; used to build short links + QR codes) ───
BASE_URL=http://localhost:8080

# ─── Internal service URLs (docker network) ───
REDIRECT_SERVICE_URL=http://redirect-service:8000
STATS_SERVICE_URL=http://stats-service:8000

# Shared secret the admin panel presents to redirect-service for write calls.
# Generate, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_TOKEN=CHANGE_ME_internal_token

# ─── Stats ───
STATS_DEFAULT_DAYS=30
TOP_LINKS_LIMIT=10

# ─── JWT / session cookie (admin panel) ───
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
COOKIE_NAME=access_token
COOKIE_SECURE=false             # set true when served over HTTPS

# ─── First admin user (bootstrapped on admin-panel startup) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password
